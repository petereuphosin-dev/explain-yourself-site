---
import { existsSync } from "node:fs";
import { fileURLToPath } from "node:url";
import BaseLayout from "../layouts/BaseLayout.astro";
import StoreButtons from "../components/StoreButtons.astro";
import { FAQ_ITEMS, SUPPORT_EMAIL } from "../consts";

const assetBase = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

const heroPosterFile = fileURLToPath(new URL("../../public/hero/hero-poster.png", import.meta.url));
const heroVideoFile = fileURLToPath(new URL("../../public/hero/hero.mp4", import.meta.url));
const heroPosterExists = existsSync(heroPosterFile);
const heroVideoExists = existsSync(heroVideoFile);
const heroPosterUrl = `${assetBase}hero/hero-poster.png`;
const heroVideoUrl = `${assetBase}hero/hero.mp4`;

const screenshots = Array.from({ length: 6 }, (_, index) => {
  const name = `s${index + 1}.png`;
  const file = fileURLToPath(new URL(`../../public/screenshots/${name}`, import.meta.url));
  return {
    name,
    url: `${assetBase}screenshots/${name}`,
    exists: existsSync(file)
  };
});
---

<BaseLayout path="/">
  <section class="relative overflow-hidden pb-20 pt-10 sm:pb-24 sm:pt-16">
    <div class="hero-glow hero-glow-left animate-drift"></div>
    <div class="hero-glow hero-glow-right animate-drift"></div>
    <div class="section-frame">
      <div class="mx-auto max-w-5xl text-center animate-rise">
        <span class="eyebrow">Mobile Party Game</span>
        <h1 class="display-title mt-6 text-5xl font-black leading-[0.92] sm:text-7xl lg:text-[6.2rem]">Explain Yourself</h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg text-[color:var(--muted)] sm:text-xl">
          The icebreaker game that forces hilarious answers.
        </p>
      </div>

      <div class="relative mx-auto mt-12 max-w-5xl">
        <div class="section-panel overflow-hidden rounded-[2rem] p-3 shadow-panel sm:rounded-[2.5rem] sm:p-5">
          <button
            id="hero-open"
            class="focus-ring group relative block aspect-[16/9] w-full overflow-hidden rounded-[1.7rem] border text-left"
            type="button"
            aria-haspopup="dialog"
            aria-controls="hero-modal"
            style="border-color: rgba(255, 255, 255, 0.08); background: linear-gradient(135deg, rgba(8, 17, 36, 0.9), rgba(23, 37, 84, 0.9));"
          >
            {heroPosterExists ? (
              <img
                src={heroPosterUrl}
                alt="Explain Yourself hero poster art"
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                loading="eager"
              />
            ) : (
              <div class="flex h-full w-full flex-col items-center justify-center bg-[radial-gradient(circle_at_20%_20%,rgba(34,211,238,0.18),transparent_24%),radial-gradient(circle_at_80%_25%,rgba(249,115,22,0.18),transparent_22%),linear-gradient(140deg,#081122,#13254a,#1f3a68)] px-6 text-center">
                <span class="eyebrow">Poster Placeholder</span>
                <p class="mt-5 max-w-xl text-3xl font-semibold sm:text-5xl">Drop in your key art to turn this frame into a premium launch trailer cover.</p>
              </div>
            )}
            <span class="absolute inset-0 bg-gradient-to-t from-black/55 via-black/10 to-transparent"></span>
            <span class="absolute inset-x-0 bottom-0 flex items-end justify-between gap-4 p-5 sm:p-8">
              <span>
                <span class="text-xs font-semibold uppercase tracking-[0.18em] text-white/70">Cinematic Preview</span>
                <span class="mt-2 block text-xl font-semibold sm:text-3xl">Tap to watch the launch teaser</span>
              </span>
              <span class="inline-flex h-20 w-20 items-center justify-center rounded-full border border-white/20 bg-white/10 text-3xl backdrop-blur animate-pulse-glow">
                ▶
              </span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </section>

  <section id="download" class="pb-12">
    <div class="section-frame">
      <div class="section-panel mx-auto max-w-5xl rounded-[2rem] p-6 shadow-panel sm:p-10">
        <div class="grid gap-8 lg:grid-cols-[1.2fr_1fr] lg:items-center">
          <div>
            <span class="eyebrow">Download Today</span>
            <h2 class="display-title mt-5 text-4xl font-black sm:text-5xl">A dedicated mobile launch page, built to convert.</h2>
            <p class="mt-4 max-w-2xl text-base text-[color:var(--muted)] sm:text-lg">
              Clear store choices, premium presentation, and room for iOS the moment it is ready. This panel is designed to feel like a flagship game landing page, not a generic app section.
            </p>
          </div>
          <div class="section-panel rounded-[1.75rem] p-5">
            <p class="text-sm uppercase tracking-[0.18em] text-[color:var(--muted)]">Install Options</p>
            <div class="mt-5">
              <StoreButtons />
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="pb-8">
    <div class="section-frame">
      <div class="grid gap-4 md:grid-cols-3">
        {[
          ["⚡", "Fast Rounds", "Start a round in seconds and keep the momentum high."],
          ["🎉", "Party Ready", "Designed for groups, couch nights, and instant replay."],
          ["💬", "No Awkward Silence", "Prompts force hilarious explanations before the room can go quiet."]
        ].map(([icon, title, copy]) => (
          <div class="section-panel rounded-3xl p-5">
            <div class="icon-chip text-xl" aria-hidden="true">{icon}</div>
            <h2 class="mt-4 text-xl font-semibold">{title}</h2>
            <p class="mt-2 text-sm text-[color:var(--muted)]">{copy}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="features" class="py-12 sm:py-16">
    <div class="section-frame">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <span class="eyebrow">Features</span>
          <h2 class="display-title mt-4 text-4xl font-black sm:text-5xl">Built for chaotic fun, polished for launch.</h2>
        </div>
        <p class="max-w-2xl text-sm text-[color:var(--muted)] sm:text-base">
          Every section stays fast, static, and GitHub Pages-friendly while selling the app like a premium release.
        </p>
      </div>
      <div class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3">
        {[
          ["🎯", "Instant setup", "No accounts, no waiting, no friction before the first laugh."],
          ["🧠", "Prompt variety", "Quick-fire questions built to trigger weird, memorable answers."],
          ["📱", "Mobile first", "Large taps, clean hierarchy, and thumb-friendly motion cues."],
          ["🕶", "Privacy forward", "A simple pitch: your play stays on your device."],
          ["🎬", "Trailer-ready presentation", "Media-first framing gives the app a launch-day feel."],
          ["🚀", "Fast deployment", "Static output ships free on GitHub Pages with no backend overhead."]
        ].map(([icon, title, copy]) => (
          <article class="section-panel rounded-3xl p-6">
            <div class="flex items-start gap-4">
              <div class="icon-chip shrink-0 text-xl" aria-hidden="true">{icon}</div>
              <div>
                <h3 class="text-xl font-semibold">{title}</h3>
                <p class="mt-2 text-sm text-[color:var(--muted)]">{copy}</p>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-8 sm:py-10">
    <div class="section-frame">
      <div class="overflow-hidden rounded-[2rem] border shadow-panel" style="border-color: var(--line); background: linear-gradient(120deg, rgba(2, 132, 199, 0.18), rgba(59, 130, 246, 0.12) 45%, rgba(249, 115, 22, 0.18));">
        <div class="grid gap-6 p-6 sm:p-8 lg:grid-cols-[1.4fr_0.9fr] lg:items-center">
          <div>
            <span class="eyebrow">Seasonal Update Banner</span>
            <h2 class="display-title mt-4 text-3xl font-black sm:text-5xl">New “After Hours” prompt pack now in rotation.</h2>
            <p class="mt-3 max-w-2xl text-sm text-[color:var(--muted)] sm:text-base">
              Use this band for seasonal drops, limited-time modes, launch beats, or community-driven prompt packs without changing the site structure.
            </p>
          </div>
          <div class="section-panel rounded-[1.5rem] p-5">
            <p class="text-sm uppercase tracking-[0.18em] text-[color:var(--muted)]">Latest Update</p>
            <p class="mt-4 text-lg font-semibold">March 3, 2026</p>
            <p class="mt-2 text-sm text-[color:var(--muted)]">Placeholder copy: announce fresh prompts, balance tweaks, event nights, or launch milestones here.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="how-it-works" class="py-12 sm:py-16">
    <div class="section-frame">
      <span class="eyebrow">How It Works</span>
      <div class="mt-5 grid gap-5 lg:grid-cols-3">
        {[
          ["01", "Pick a round", "Choose a mode, hand over the phone, and let the room settle in."],
          ["02", "Read the prompt", "Each player gets a question built to force a fast explanation."],
          ["03", "Defend your answer", "The funniest reasoning wins the moment, and the next round starts immediately."]
        ].map(([number, title, copy]) => (
          <article class="section-panel rounded-[1.8rem] p-6">
            <div class="flex items-center justify-between gap-4">
              <span class="display-title text-4xl font-black text-[color:var(--accent)]">{number}</span>
              <span class="icon-chip" aria-hidden="true">{number === "01" ? "🎮" : number === "02" ? "🗣" : "🏆"}</span>
            </div>
            <h2 class="mt-6 text-2xl font-semibold">{title}</h2>
            <p class="mt-3 text-sm text-[color:var(--muted)]">{copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="screenshots" class="py-12 sm:py-16">
    <div class="section-frame">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <span class="eyebrow">Screenshots</span>
          <h2 class="display-title mt-4 text-4xl font-black sm:text-5xl">A gallery that sells the in-app vibe.</h2>
        </div>
        <p class="max-w-2xl text-sm text-[color:var(--muted)] sm:text-base">Replace the six local images in `public/screenshots/` for a live gallery. The lightbox supports keyboard arrows and `Esc`.</p>
      </div>
      <div class="mt-8 grid gap-4 sm:grid-cols-2 xl:grid-cols-3">
        {screenshots.map((shot, index) => (
          <button
            class="focus-ring screenshot-trigger section-panel group relative aspect-[10/18] overflow-hidden rounded-[1.8rem] text-left"
            type="button"
            data-index={index}
            data-image={shot.url}
            data-alt={`Explain Yourself screenshot ${index + 1}`}
            aria-label={`Open screenshot ${index + 1}`}
          >
            {shot.exists ? (
              <img
                src={shot.url}
                alt={`Explain Yourself screenshot ${index + 1}`}
                class="h-full w-full object-cover transition duration-500 group-hover:scale-[1.03]"
                loading="lazy"
              />
            ) : (
              <div class="flex h-full w-full flex-col items-center justify-center bg-[linear-gradient(165deg,#0b1328,#102042,#132c59)] px-5 text-center">
                <span class="text-xs font-semibold uppercase tracking-[0.18em] text-white/65">Missing Screenshot</span>
                <span class="mt-4 text-xl font-semibold">Add {shot.name}</span>
                <span class="mt-2 text-sm text-white/70">Place your real PNG file in `public/screenshots/`.</span>
              </div>
            )}
            <span class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-t from-black/50 to-transparent"></span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <section class="py-12 sm:py-16">
    <div class="section-frame">
      <span class="eyebrow">Testimonials</span>
      <div class="mt-6 grid gap-5 lg:grid-cols-3">
        {[
          ["Alex P", "“It turned a dead room into twenty minutes of instant chaos.”"],
          ["Jordan M", "“The prompts are absurd in the best way, and no one gets to hide.”"],
          ["Sam K", "“It feels like a party game trailer, except it is the whole app.”"]
        ].map(([name, quote]) => (
          <blockquote class="section-panel rounded-[1.8rem] p-6">
            <p class="text-lg font-medium">{quote}</p>
            <footer class="mt-5 text-sm uppercase tracking-[0.18em] text-[color:var(--muted)]">{name}</footer>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <section id="faq" class="py-12 sm:py-16">
    <div class="section-frame">
      <div class="grid gap-8 lg:grid-cols-[0.9fr_1.1fr]">
        <div>
          <span class="eyebrow">FAQ</span>
          <h2 class="display-title mt-5 text-4xl font-black sm:text-5xl">Clear answers without breaking the mood.</h2>
          <p class="mt-4 text-sm text-[color:var(--muted)] sm:text-base">The accordion keeps the page compact while staying keyboard-friendly and screen-reader readable.</p>
        </div>
        <div class="space-y-3">
          {FAQ_ITEMS.map(({ question, answer }, index) => (
            <div class="section-panel overflow-hidden rounded-3xl">
              <button
                class="focus-ring faq-toggle flex w-full items-center justify-between gap-4 px-5 py-4 text-left"
                type="button"
                aria-expanded={index === 0 ? "true" : "false"}
                aria-controls={`faq-panel-${index}`}
                id={`faq-trigger-${index}`}
              >
                <span class="text-base font-semibold sm:text-lg">{question}</span>
                <span class="text-2xl" aria-hidden="true">+</span>
              </button>
              <div
                id={`faq-panel-${index}`}
                class={index === 0 ? "block px-5 pb-5" : "hidden px-5 pb-5"}
                role="region"
                aria-labelledby={`faq-trigger-${index}`}
              >
                <p class="text-sm text-[color:var(--muted)]">{answer}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section id="press-teaser" class="py-12 sm:py-16">
    <div class="section-frame">
      <div class="section-panel overflow-hidden rounded-[2rem] p-6 shadow-panel sm:p-8">
        <div class="grid gap-8 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
          <div>
            <span class="eyebrow">Press</span>
            <h2 class="display-title mt-5 text-4xl font-black sm:text-5xl">Need a clean media handoff?</h2>
            <p class="mt-4 max-w-2xl text-sm text-[color:var(--muted)] sm:text-base">
              The dedicated press page includes short and long descriptions, feature bullets, asset placeholders, and a press kit link.
            </p>
          </div>
          <div class="flex justify-start lg:justify-end">
            <a class="focus-ring inline-flex min-h-[3.5rem] items-center justify-center rounded-2xl px-6 text-sm font-semibold text-white" href={`${assetBase}press`} style="background: linear-gradient(135deg, #0f766e, #2563eb);">
              Visit Press Page
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-12 sm:py-20">
    <div class="section-frame">
      <div class="section-panel rounded-[2rem] p-6 text-center shadow-panel sm:p-10">
        <span class="eyebrow">Final Call</span>
        <h2 class="display-title mx-auto mt-5 max-w-4xl text-4xl font-black sm:text-6xl">Bring Explain Yourself to the next party night.</h2>
        <p class="mx-auto mt-4 max-w-2xl text-sm text-[color:var(--muted)] sm:text-base">Keep the conversion path obvious and premium all the way to the footer.</p>
        <div class="mt-8">
          <StoreButtons />
        </div>
      </div>
    </div>
  </section>

  <footer class="border-t py-10" style="border-color: var(--line);">
    <div class="section-frame flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="font-semibold">Explain Yourself</p>
        <p class="mt-2 text-sm text-[color:var(--muted)]">Support: {SUPPORT_EMAIL}</p>
      </div>
      <div class="flex flex-wrap items-center gap-4 text-sm text-[color:var(--muted)]">
        <a class="focus-ring transition hover:text-[color:var(--text)]" href={`${assetBase}privacy`}>Privacy</a>
        <a class="focus-ring transition hover:text-[color:var(--text)]" href={`${assetBase}terms`}>Terms</a>
        <a class="focus-ring transition hover:text-[color:var(--text)]" href={`${assetBase}press`}>Press</a>
      </div>
    </div>
  </footer>

  <div id="hero-modal" class="modal-shell" role="dialog" aria-modal="true" aria-labelledby="hero-modal-title">
    <div class="section-panel relative w-full max-w-5xl rounded-[2rem] p-4 shadow-panel sm:p-5">
      <button id="hero-close" class="focus-ring absolute right-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-2xl border text-lg" type="button" aria-label="Close video modal" style="border-color: var(--line);">×</button>
      <h2 id="hero-modal-title" class="sr-only">Launch teaser</h2>
      <div class="overflow-hidden rounded-[1.6rem] border" style="border-color: rgba(255, 255, 255, 0.08);">
        {heroPosterExists ? (
          <img src={heroPosterUrl} alt="" class={`hero-modal-poster ${heroVideoExists ? "hidden" : "block"} h-auto w-full`} />
        ) : (
          <div class={`hero-modal-poster ${heroVideoExists ? "hidden" : "flex"} aspect-[16/9] w-full items-center justify-center bg-[linear-gradient(165deg,#081122,#13254a,#1f3a68)] px-6 text-center`}>
            <p class="max-w-lg text-lg font-medium">Add `public/hero/hero-poster.png` for custom key art.</p>
          </div>
        )}
        {heroVideoExists ? (
          <video id="hero-video" class="aspect-[16/9] w-full bg-black" controls playsinline poster={heroPosterExists ? heroPosterUrl : undefined}>
            <source src={heroVideoUrl} type="video/mp4" />
            Your browser does not support the video tag.
          </video>
        ) : (
          <div class="px-6 py-8 text-center">
            <p class="text-lg font-semibold">Trailer placeholder</p>
            <p class="mt-2 text-sm text-[color:var(--muted)]">Add `public/hero/hero.mp4` to enable playback. Until then, the poster remains the hero media.</p>
          </div>
        )}
      </div>
    </div>
  </div>

  <div id="lightbox" class="modal-shell" role="dialog" aria-modal="true" aria-labelledby="lightbox-title">
    <div class="section-panel relative w-full max-w-5xl rounded-[2rem] p-4 shadow-panel sm:p-5">
      <button id="lightbox-close" class="focus-ring absolute right-4 top-4 inline-flex h-11 w-11 items-center justify-center rounded-2xl border text-lg" type="button" aria-label="Close screenshot lightbox" style="border-color: var(--line);">×</button>
      <button id="lightbox-prev" class="focus-ring absolute left-4 top-1/2 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-2xl border text-lg" type="button" aria-label="Previous screenshot" style="border-color: var(--line);">←</button>
      <button id="lightbox-next" class="focus-ring absolute right-4 top-1/2 inline-flex h-11 w-11 -translate-y-1/2 items-center justify-center rounded-2xl border text-lg" type="button" aria-label="Next screenshot" style="border-color: var(--line);">→</button>
      <h2 id="lightbox-title" class="sr-only">Screenshot viewer</h2>
      <div class="overflow-hidden rounded-[1.6rem] border" style="border-color: rgba(255, 255, 255, 0.08);">
        <img id="lightbox-image" src="" alt="" class="aspect-[10/18] max-h-[82vh] w-full object-contain bg-black/30" />
      </div>
    </div>
  </div>

  <script is:inline>
    (() => {
      const heroModal = document.getElementById("hero-modal");
      const heroOpen = document.getElementById("hero-open");
      const heroClose = document.getElementById("hero-close");
      const heroVideo = document.getElementById("hero-video");

      const openModal = (modal) => {
        modal?.setAttribute("data-open", "true");
        document.body.style.overflow = "hidden";
      };

      const closeModal = (modal, onClose) => {
        modal?.setAttribute("data-open", "false");
        document.body.style.overflow = "";
        onClose?.();
      };

      heroOpen?.addEventListener("click", () => {
        openModal(heroModal);
        if (heroVideo instanceof HTMLVideoElement) {
          heroVideo.currentTime = 0;
          heroVideo.play().catch(() => undefined);
        }
      });

      heroClose?.addEventListener("click", () => {
        closeModal(heroModal, () => {
          if (heroVideo instanceof HTMLVideoElement) {
            heroVideo.pause();
          }
        });
      });

      heroModal?.addEventListener("click", (event) => {
        if (event.target === heroModal) {
          heroClose?.dispatchEvent(new Event("click"));
        }
      });

      const lightbox = document.getElementById("lightbox");
      const lightboxImage = document.getElementById("lightbox-image");
      const lightboxClose = document.getElementById("lightbox-close");
      const lightboxPrev = document.getElementById("lightbox-prev");
      const lightboxNext = document.getElementById("lightbox-next");
      const screenshotButtons = Array.from(document.querySelectorAll(".screenshot-trigger"));
      let activeIndex = 0;

      const setLightbox = (index) => {
        const button = screenshotButtons[index];
        if (!button || !(lightboxImage instanceof HTMLImageElement)) {
          return;
        }

        activeIndex = index;
        lightboxImage.src = button.getAttribute("data-image") || "";
        lightboxImage.alt = button.getAttribute("data-alt") || "Screenshot";
      };

      screenshotButtons.forEach((button, index) => {
        button.addEventListener("click", () => {
          setLightbox(index);
          openModal(lightbox);
        });
      });

      lightboxClose?.addEventListener("click", () => closeModal(lightbox));
      lightbox?.addEventListener("click", (event) => {
        if (event.target === lightbox) {
          closeModal(lightbox);
        }
      });

      lightboxPrev?.addEventListener("click", () => {
        setLightbox((activeIndex - 1 + screenshotButtons.length) % screenshotButtons.length);
      });

      lightboxNext?.addEventListener("click", () => {
        setLightbox((activeIndex + 1) % screenshotButtons.length);
      });

      document.addEventListener("keydown", (event) => {
        const heroOpenState = heroModal?.getAttribute("data-open") === "true";
        const lightboxOpenState = lightbox?.getAttribute("data-open") === "true";

        if (event.key === "Escape") {
          if (heroOpenState) {
            heroClose?.dispatchEvent(new Event("click"));
          }
          if (lightboxOpenState) {
            lightboxClose?.dispatchEvent(new Event("click"));
          }
        }

        if (!lightboxOpenState) {
          return;
        }

        if (event.key === "ArrowLeft") {
          lightboxPrev?.dispatchEvent(new Event("click"));
        }

        if (event.key === "ArrowRight") {
          lightboxNext?.dispatchEvent(new Event("click"));
        }
      });

      document.querySelectorAll(".faq-toggle").forEach((button) => {
        button.addEventListener("click", () => {
          const expanded = button.getAttribute("aria-expanded") === "true";
          const panelId = button.getAttribute("aria-controls");
          const panel = panelId ? document.getElementById(panelId) : null;
          button.setAttribute("aria-expanded", String(!expanded));
          const icon = button.querySelector('[aria-hidden="true"]');
          if (icon) {
            icon.textContent = expanded ? "+" : "−";
          }
          panel?.classList.toggle("hidden", expanded);
          panel?.classList.toggle("block", !expanded);
        });
      });
    })();
  </script>
</BaseLayout>
